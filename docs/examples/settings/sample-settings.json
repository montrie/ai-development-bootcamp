{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(ls -la)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(realpath:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",

      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(uname:*)",

      "Bash(jq:*)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git diff --stat && git status)",
      "Bash(git log --oneline | head -20)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git ls-files *)",

      "Bash(GH_CONFIG_DIR=~/.config/gh gh workflow run *)",
      "Bash(GH_CONFIG_DIR=~/.config/gh gh workflow watch *)",
      "WebFetch(domain:api.github.com)",

      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npx playwright test)",

      "Bash(mvnw compile)",
      "Bash(mvnw test)",
      "Bash(mvnw verify)",

      "Bash(terraform validate)",
      "Bash(terraform fmt *)",
      "Bash(tflint *)",

      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      
      "WebSearch",
      "WebFetch(domain:cloud.google.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      
      "mcp__context7__resolve-library-id",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__github__get_file_contents",
      "mcp__context7__query-docs",
      "mcp__github__list_commits",
      "mcp__github__search_issues",
      "mcp__github__search_code"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "ask": [
      "WebFetch",
      "WebSearch",
      "Bash"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "say 'Claude needs permissions'"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs permissions\" with title \"Claude Code - permission\"'"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "say 'Claude has a question'"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code - question\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "say 'Your Claude Task is Finished'"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task Complete\" with title \"Claude Code finished\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "allowManagedHooksOnly": true,
  "allowManagedPermissionRulesOnly": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "strictKnownMarketplaces": [],
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "network": {
      "allowedDomains": [],
      "allowUnixSockets": [
        "/Users/David.Schmitz/.gnupg/S.gpg-agent",
        "/Users/David.Schmitz/.gnupg/S.gpg-agent.browser",
        "/Users/David.Schmitz/.gnupg/S.gpg-agent.extra",
        "/Users/David.Schmitz/.gnupg/S.gpg-agent.ssh",
        "/Users/David.Schmitz/.gnupg/S.keyboxd",
        "/Users/David.Schmitz/.gnupg/S.scdaemon"
      ],
      "allowAllUnixSockets": false,
      "allowLocalBinding": false
    },
    "filesystem": {
      "allowWrite": [
        "~/tmp/build",
        "~/.gnupg"
      ]
    },
    "enableWeakerNestedSandbox": false,
    "excludedCommands": []
  },
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  }
}
